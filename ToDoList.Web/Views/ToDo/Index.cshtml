@model List<ToDoList.Models.ToDoItem>

<h1>My Todo List</h1>
<a asp-action="Create">+ Add New Item</a>
@if (!Model.Any())
{
    <p>No items yet!</p>
}
else
{
    <ul>
        @foreach (var item in Model)
        {
            <li>
                <strong>@item.Title</strong> - 
                @item.Description -
                @item.TargetDayTime.ToString("dd/MM/yyyy HH:mm") -
                @item.ItemType -
                @if (item is ToDoList.Models.Call call)
                {
                    <span>Invited: @string.Join(", ", call.InvitedPerson)</span>
                }
                @if (item is ToDoList.Models.Meeting meeting)
                {
                    <span>Invited: @string.Join(", ", meeting.InvitedPerson)</span>
                    <span>Place: @meeting.Place</span>
                }
                @if (item is ToDoList.Models.DateOfBirth dob)
                {
                    <span>Name Of the person with DoB: @dob.NameOfPersonWithDoB</span>
                }
                @if (item.IsCompleted)
                {
                    <span>✅ Completed</span>
                }
                else
                {
                    <span>⏳ Pending</span>
                }
                <form asp-action="Complete" asp-route-id="@item.Id" method="post">
                    <button type="submit">Complete</button>
                </form>
                <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                    <button type="submit">Delete</button>
                </form>
            </li>
        }
    </ul>
}