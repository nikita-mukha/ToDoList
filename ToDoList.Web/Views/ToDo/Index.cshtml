@model List<ToDoList.Models.ToDoItem>

@{
    var showCompleted = Context.Request.Query["showCompleted"] == "true";
    var visibleItems = showCompleted
        ? Model
        : Model.Where(i => !i.IsCompleted).ToList();
}

<h1 class="mb-4">@User.Identity!.Name's List</h1>


<div class="d-flex gap-2 mb-3">
<a asp-action="Create" class="btn btn-primary">+ Add New Item</a>
@if (showCompleted)
{
    <a asp-action="Index" class="btn btn-outline-secondary">Hide Completed</a>
}

else
{
    <a asp-action="Index" asp-route-showCompleted="true" class="btn btn-outline-secondary">Show Completed</a>
}
</div>

@if (!visibleItems.Any())
{
    <p>No items yet!</p>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var item in visibleItems.OrderBy(i => i.IsCompleted).ThenBy(i => i.TargetDayTime))
        {
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h5 class="card-title mb-1">@item.Title</h5>
                            <div class="text-muted small">
                                @item.TargetDayTime.ToString("dd/MM/yyyy HH:mm") · @item.ItemType
                            </div>
                        </div>

                        @if (item.IsCompleted)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <p class="card-text mb-2">@item.Description</p>
                    }

                    @if (item is ToDoList.Models.Call call)
                    {
                        <p class="mb-1"><strong>Invited:</strong> @string.Join(", ", call.InvitedPerson)</p>
                    }

                    @if (item is ToDoList.Models.Meeting meeting)
                    {
                        <p class="mb-1"><strong>Invited:</strong> @string.Join(", ", meeting.InvitedPerson)</p>
                        <p class="mb-1"><strong>Place:</strong> @meeting.Place</p>
                    }

                    @if (item is ToDoList.Models.DateOfBirth dob)
                    {
                        <p class="mb-1"><strong>Person:</strong> @dob.NameOfPersonWithDoB</p>
                    }

                    <div class="d-flex gap-2 mt-3">
                        @if (!item.IsCompleted)
                        {
                            <form asp-action="Complete" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-success">Complete</button>
                            </form>
                        }

                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>

                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}