@model List<ToDoList.Models.ToDoItem>

@{
    var showCompleted = Context.Request.Query["showCompleted"] == "true";
    var startDate = Context.Request.Query["startDate"].ToString();
    var endDate = Context.Request.Query["endDate"].ToString();
    var title = Context.Request.Query["title"].ToString();

    List<ToDoList.Models.ToDoItem> visibleItems;

    if (showCompleted)
    {
        visibleItems = Model;
    }
    else
    {
        visibleItems = Model.Where(item => !item.IsCompleted).ToList();
    }
}

<h1 class="mb-4">@User.Identity!.Name's List</h1>

<form asp-action="Index" method="get" class="d-flex gap-2 align-items-end mb-3">
    <input type="hidden" name="showCompleted" value="@showCompleted.ToString().ToLower()" />
    <input type="hidden" name="title" value="@title" />

    <div>
        <label for="startDate" class="form-label">From</label>
        <input type="date"
               id="startDate"
               name="startDate"
               class="form-control"
               value="@startDate"
               onchange="syncDateRange(); this.form.submit()" />
    </div>

    <div>
        <label for="endDate" class="form-label">To</label>
        <input type="date"
               id="endDate"
               name="endDate"
               class="form-control"
               value="@endDate"
               onchange="syncDateRange(); this.form.submit()" />
    </div>

    <a asp-action="Index"
       asp-route-showCompleted="@showCompleted"
       class="btn btn-outline-secondary">Clear</a>
</form>

<form asp-action="Index" method="get" class="mb-3">
    <input type="hidden" name="showCompleted" value="@showCompleted.ToString().ToLower()" />
    <input type="hidden" name="startDate" value="@startDate" />
    <input type="hidden" name="endDate" value="@endDate" />

    <div>
        <label for="title" class="form-label">Search by title</label>
        <input type="text"
               id="title"
               name="title"
               class="form-control"
               value="@title"
               placeholder="Type a title..." />
        <button type="submit" class="btn btn-outline-primary mt-2">Search</button>
        <a asp-action="Index"
           asp-route-showCompleted="@showCompleted"
           asp-route-startDate="@startDate"
           asp-route-endDate="@endDate"
           class="btn btn-outline-secondary mt-2 ms-2">Clear Search</a>
    </div>
</form>

<div class="d-flex gap-2 mb-3">
<a asp-action="Create" class="btn btn-primary">+ Add New Item</a>
@if (showCompleted)
{
    <a asp-action="Index" asp-route-startDate="@startDate" asp-route-endDate="@endDate" asp-route-title="@title" class="btn btn-outline-secondary">Hide Completed</a>
}

else
{
    <a asp-action="Index" asp-route-showCompleted="true" asp-route-startDate="@startDate" asp-route-endDate="@endDate" asp-route-title="@title" class="btn btn-outline-secondary">Show Completed</a>
}
</div>

@if (!visibleItems.Any())
{
    <p>No items yet!</p>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var item in visibleItems.OrderBy(i => i.IsCompleted).ThenBy(i => i.TargetDayTime))
        {
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h5 class="card-title mb-1">@item.Title</h5>
                            <div class="text-muted small">
                                @item.TargetDayTime.ToString("dd/MM/yyyy HH:mm") · @item.ItemType
                            </div>
                        </div>

                        @if (item.IsCompleted)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <p class="card-text mb-2">@item.Description</p>
                    }

                    @if (item is ToDoList.Models.Call call)
                    {
                        <p class="mb-1"><strong>Invited:</strong> @string.Join(", ", call.InvitedPerson)</p>
                    }

                    @if (item is ToDoList.Models.Meeting meeting)
                    {
                        <p class="mb-1"><strong>Invited:</strong> @string.Join(", ", meeting.InvitedPerson)</p>
                        <p class="mb-1"><strong>Place:</strong> @meeting.Place</p>
                    }

                    @if (item is ToDoList.Models.DateOfBirth dob)
                    {
                        <p class="mb-1"><strong>Person:</strong> @dob.NameOfPersonWithDoB</p>
                    }

                    <div class="d-flex gap-2 mt-3">
                        @if (!item.IsCompleted)
                        {
                            <form asp-action="Complete" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-success">Complete</button>
                            </form>
                        }

                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>

                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
function syncDateRange() {
    const startDate = document.getElementById('startDate');
    const endDate = document.getElementById('endDate');

    if (!startDate || !endDate || !startDate.value || !endDate.value) {
        return;
    }

    if (endDate.value < startDate.value) {
        endDate.value = startDate.value;
    }
}
</script>
