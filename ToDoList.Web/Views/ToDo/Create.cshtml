@model ToDoList.Web.Models.CreateToDoItemViewModel

@{
    ViewBag.Title = "Create Item";
    Layout = "_Layout";
}

<h1 class="mb-4">Create New Item</h1>

<form asp-action="Create" method="post" class="card shadow-sm p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    
    <input asp-for="IgnoreTimeConflicts" type="hidden" />
    <input asp-for="ConfirmedConflictKey" type="hidden" />
    
    <div class="mb-3">
        <label asp-for="Title" class="form-label">Title</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description (optional)</label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="TargetDayTime" class="form-label">Date and Time</label>
        <input asp-for="TargetDayTime" asp-format="{0:yyyy-MM-ddTHH:mm}" 
               type="datetime-local" class="form-control" />
        <span asp-validation-for="TargetDayTime" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ItemType" class="form-label">Type</label>
        <select asp-for="ItemType" id="itemType" onchange="showFields()" class="form-select">
            @foreach (var type in Enum.GetValues<ToDoItemTypes>())
            {
                <option value="@((int)type)">@type</option>
            }
        </select>
    </div>

    <div id="invitedPersonsField" class="mb-3" style="display:none">
        <label asp-for="InvitedPersons" class="form-label">Invited Persons (comma separated)</label>
        <input asp-for="InvitedPersons" class="form-control" />
        <span asp-validation-for="InvitedPersons" class="text-danger"></span>
    </div>

    <div id="placeField" class="mb-3" style="display:none">
        <label asp-for="Place" class="form-label">Place</label>
        <input asp-for="Place" class="form-control" />
        <span asp-validation-for="Place" class="text-danger"></span>
    </div>

    <div id="personNameField" class="mb-3" style="display:none">
        <label asp-for="PersonName" class="form-label">Person Name</label>
        <input asp-for="PersonName" class="form-control" />
        <span asp-validation-for="PersonName" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsRecurring" class="form-check-input" id="isRecurring" onchange="showRecurrenceFields()"/>
        <label asp-for="IsRecurring" class="form-check-label">Repeat this item</label>
    </div>

    <div id="recurrenceFields" style="display:none">
        <div class="mb-3">
            <label asp-for="RecurrenceFrequency" class="form-label">Frequency</label>
            <select asp-for="RecurrenceFrequency" class="form-select">
                <option value="">Choose frequency</option>
                @foreach (var frequency in Enum.GetValues<RecurrenceFrequency>())
                {
                    <option value="@((int)frequency)">@frequency</option>
                }
            </select>
            <span asp-validation-for="RecurrenceFrequency" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RecurrenceInterval" class="form-label">Repeat every</label>
            <input asp-for="RecurrenceInterval" type="number" min="1" class="form-control" />
            <span asp-validation-for="RecurrenceInterval" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RecurrenceEndDateTime" class="form-label">End repeat on (optional)</label>
            <input asp-for="RecurrenceEndDateTime" asp-format="{0:yyyy-MM-ddTHH:mm}"
                   type="datetime-local" class="form-control" />
            <span asp-validation-for="RecurrenceEndDateTime" class="text-danger"></span>
        </div>
    </div>
            
    <div class="d-flex gap-2 mt-3">
        @if (Model.IgnoreTimeConflicts)
        {
            <button type="submit" class="btn btn-warning">Create anyway</button>
        }
        else
        {
            <button type="submit" class="btn btn-primary">Create</button>
        }

        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

<script>
    function showFields() {
        var type = document.getElementById('itemType').value;

        document.getElementById('invitedPersonsField').style.display = 'none';
        document.getElementById('placeField').style.display = 'none';
        document.getElementById('personNameField').style.display = 'none';

        if (type == 1) { // Call
            document.getElementById('invitedPersonsField').style.display = 'block';
        }
        if (type == 2) { // Meeting
            document.getElementById('invitedPersonsField').style.display = 'block';
            document.getElementById('placeField').style.display = 'block';
        }
        if (type == 3) { // DateOfBirth
            document.getElementById('personNameField').style.display = 'block';
        }
    }

    showFields();
</script>

<script>
    function showRecurrenceFields() {
        var isRecurring = document.getElementById('isRecurring').checked;
        document.getElementById('recurrenceFields').style.display = isRecurring ? 'block' : 'none';
    }

    showRecurrenceFields();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}