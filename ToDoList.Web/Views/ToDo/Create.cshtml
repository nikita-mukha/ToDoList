@model ToDoList.Web.Models.CreateToDoItemViewModel
@using ToDoList.Enums

@{
    ViewBag.Title = "Create Item";
    Layout = "_Layout";
}

<h1>Create New Item</h1>
<form asp-action="Create" method="post">
    
    <div>
        <label asp-for="Title">Title</label>
        <input asp-for="Title" />
        <span asp-validation-for="Title" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Description">Description (optional)</label>
        <input asp-for="Description" />
    </div>

    <div>
        <label asp-for="TargetDayTime">Date and Time</label>
        <input asp-for="TargetDayTime" type="datetime-local" />
        <span asp-validation-for="TargetDayTime" style="color:red"></span>
    </div>

    <div>
        <label asp-for="ItemType">Type</label>
        <select asp-for="ItemType" id="itemType" onchange="showFields()">
            @foreach (var type in Enum.GetValues<ToDoItemTypes>())
            {
                <option value="@((int)type)">@type</option>
            }
        </select>
    </div>
    
    <div id="invitedPersonsField" style="display:none">
        <label asp-for="InvitedPersons">Invited Persons (comma separated)</label>
        <input asp-for="InvitedPersons"/>
        <span asp-validation-for="InvitedPersons" style="color:red"></span>
    </div>

    <div id="placeField" style="display:none">
        <label asp-for="Place">Place</label>
        <input asp-for="Place" />
        <span asp-validation-for="Place" style="color:red"></span>
    </div>

    <div id="personNameField" style="display:none">
        <label asp-for="PersonName">Person Name</label>
        <input asp-for="PersonName" />
        <span asp-validation-for="PersonName" style="color:red"></span>
    </div>

    <button type="submit">Create</button>
    <a asp-action="Index">Cancel</a>
</form>

<script>
    function showFields() {
        var type = document.getElementById('itemType').value;
        
        document.getElementById('invitedPersonsField').style.display = 'none';
        document.getElementById('placeField').style.display = 'none';
        document.getElementById('personNameField').style.display = 'none';
        
        if (type == 1) { // Call
            document.getElementById('invitedPersonsField').style.display = 'block';
        }
        if (type == 2) { // Meeting
            document.getElementById('invitedPersonsField').style.display = 'block';
            document.getElementById('placeField').style.display = 'block';
        }
        if (type == 3) { // DateOfBirth
            document.getElementById('personNameField').style.display = 'block';
        }
    }
    
    showFields();
    </script>
    
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}