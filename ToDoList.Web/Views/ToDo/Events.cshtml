@model List<ToDoList.Models.ToDoEvent>

@{
    ViewBag.Title = "Event Log";
    Layout = "_Layout";
}

<h1 class="mb-4">Event Log</h1>

@if (!Model.Any())
{
    <p>No events have been recorded yet.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Date</th>
            <th>Event Type</th>
            <th>Title</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.OrderByDescending(e => e.Date))
        {
            var eventDisplay = GetEventDisplay(item.EventType);
            <tr>
                <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <span class="badge @eventDisplay.BadgeClass">@eventDisplay.Text</span>
                </td>
                <td>@item.Title</td>
            </tr>
        }
        </tbody>
    </table>
}

@functions {
    private static (string Text, string BadgeClass) GetEventDisplay(ToDoList.Enums.ToDoEventTypes eventType)
    {
        return eventType switch
        {
            ToDoList.Enums.ToDoEventTypes.ItemAdded => ("Added", "bg-primary"),
            ToDoList.Enums.ToDoEventTypes.ItemCompleted => ("Completed", "bg-success"),
            ToDoList.Enums.ToDoEventTypes.ItemRemoved => ("Removed", "bg-danger"),
            ToDoList.Enums.ToDoEventTypes.ItemEdited => ("Edited", "bg-warning text-dark"),
            _ => (eventType.ToString(), "bg-secondary")
        };
    }
}